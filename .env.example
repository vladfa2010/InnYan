# Railway automatically assigns PORT — do not set manually
# PORT=3000

# Yandex Search API
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# Kimi OAuth (optional — only if you use auth features)
APP_ID=your_app_id
APP_SECRET=your_app_secret
VITE_APP_ID=your_app_id

# Database (optional — provided by Railway if you add MySQL plugin)
DATABASE_URL=mysql://user:pass@host:port/db
